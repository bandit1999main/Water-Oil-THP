rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Thailand Post Oil, Water, & Attendance Collections (dynamic & static) ---
    match /{collectionId}/{document} {
      allow read: if request.auth != null && (
        collectionId == 'employees' ||
        collectionId.matches('employees_[0-9]+_[0-9]+') ||
        collectionId == 'water_employees' ||
        collectionId.matches('water_employees_[0-9]+_[0-9]+') ||
        collectionId == 'personnel' ||
        collectionId == 'templates' ||
        collectionId == 'signatory_profiles' ||
        collectionId == 'route_data' ||
        collectionId == 'global_settings' ||
        collectionId == 'configs' ||
        collectionId == 'monthly_summaries' ||
        collectionId.matches('attendance_[0-9]+_[0-9]+')
      );
      allow write: if request.auth != null && (
        request.auth.token.email == 'bandit1999main@gmail.com' ||
        get(/databases/$(database)/documents/app_users/$(request.auth.uid)).data.role == 'admin'
      ) && (
        collectionId == 'employees' ||
        collectionId.matches('employees_[0-9]+_[0-9]+') ||
        collectionId == 'water_employees' ||
        collectionId.matches('water_employees_[0-9]+_[0-9]+') ||
        collectionId == 'personnel' ||
        collectionId == 'templates' ||
        collectionId == 'signatory_profiles' ||
        collectionId == 'route_data' ||
        collectionId == 'global_settings' ||
        collectionId == 'configs' ||
        collectionId == 'monthly_summaries' ||
        collectionId.matches('attendance_[0-9]+_[0-9]+')
      );
    }

    match /app_users/{userId} {
      // Any logged-in user can read user profiles
      allow read: if request.auth != null;

      // Any logged-in user can CREATE their own document (first-time registration)
      // Enforce that new users must have the default 'user' role
      allow create: if request.auth != null && 
                    request.auth.uid == userId && 
                    request.resource.data.role == 'user';

      // Only the user themselves (without changing their role) OR admin can update
      allow update: if request.auth != null && (
        (request.auth.uid == userId && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']))) ||
        request.auth.token.email == 'bandit1999main@gmail.com' ||
        get(/databases/$(database)/documents/app_users/$(request.auth.uid)).data.role == 'admin'
      );

      // Only the user themselves OR admin can delete
      allow delete: if request.auth != null && (
        request.auth.uid == userId ||
        request.auth.token.email == 'bandit1999main@gmail.com' ||
        get(/databases/$(database)/documents/app_users/$(request.auth.uid)).data.role == 'admin'
      );
    }
  }
}
