rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Projects collection: everyone can read, only admin can write
    match /projects/{project} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == 'bandit1999main@gmail.com';
    }
    
    // About (Resume) collection: everyone can read, only admin can write
    match /about/{document} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == 'bandit1999main@gmail.com';
    }
    
    // Favorites collection: user can only read/write their own favorites
    match /favorites/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Comments collection: everyone can read, logged in users can write, owner/admin can delete
    match /comments/{comment} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && (request.auth.token.email == 'bandit1999main@gmail.com' || request.auth.uid == resource.data.uid);
    }

    // --- Thailand Post Oil, Water, & Attendance Collections (dynamic & static) ---
    match /{collectionId}/{document} {
      allow read: if request.auth != null && (
        collectionId == 'employees' ||
        collectionId.matches('employees_[0-9]+_[0-9]+') ||
        collectionId == 'water_employees' ||
        collectionId.matches('water_employees_[0-9]+_[0-9]+') ||
        collectionId == 'personnel' ||
        collectionId == 'templates' ||
        collectionId == 'signatory_profiles' ||
        collectionId == 'route_data' ||
        collectionId == 'global_settings' ||
        collectionId.matches('attendance_[0-9]+_[0-9]+')
      );
      allow write: if request.auth != null && request.auth.token.email == 'bandit1999main@gmail.com' && (
        collectionId == 'employees' ||
        collectionId.matches('employees_[0-9]+_[0-9]+') ||
        collectionId == 'water_employees' ||
        collectionId.matches('water_employees_[0-9]+_[0-9]+') ||
        collectionId == 'personnel' ||
        collectionId == 'templates' ||
        collectionId == 'signatory_profiles' ||
        collectionId == 'route_data' ||
        collectionId == 'global_settings' ||
        collectionId.matches('attendance_[0-9]+_[0-9]+')
      );
    }
    match /app_users/{userId} {
      // Any logged-in user can read their own profile (needed for real-time approval listener)
      // Admin can read all user profiles
      allow read: if request.auth != null &&
        (request.auth.uid == userId || request.auth.token.email == 'bandit1999main@gmail.com');

      // Any logged-in user can CREATE their own document (first-time registration)
      allow create: if request.auth != null && request.auth.uid == userId;

      // Only the user themselves OR admin can update/delete
      allow update, delete: if request.auth != null &&
        (request.auth.uid == userId || request.auth.token.email == 'bandit1999main@gmail.com');
    }
  }
}
